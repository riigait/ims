# =============================================================================
# IMS — Environment Variables
# =============================================================================
# This is the single reference for all env vars across the project.
# Each section maps to a different .env file you need to create:
#
#   Section A  →  copy to  .env            (Docker Compose, at repo root)
#   Section B  →  copy to  backend/.env    (Node.js / Express)
#   Section C  →  copy to  frontend/.env   (Vite)
#
# Never commit any real .env file. Keep secrets private.
# =============================================================================


# -----------------------------------------------------------------------------
# A. Docker Compose  →  .env
# -----------------------------------------------------------------------------

# PostgreSQL
POSTGRES_DB=ims_db
POSTGRES_USER=ims_user
POSTGRES_PASSWORD=change-this-password

# JWT — must match JWT_SECRET in backend/.env
JWT_SECRET=change-this-to-a-long-random-secret

# Port the app is accessible on (default: 80)
APP_PORT=80

# WSL / SSH access (local dev only — never commit real values)
WSL_DISTRO=Ubuntu
WSL_USER=your-wsl-username
WSL_PASSWORD=your-wsl-password
WSL_SSH_PORT=22


# -----------------------------------------------------------------------------
# B. Backend (Node.js / Express)  →  backend/.env
# -----------------------------------------------------------------------------

# PostgreSQL connection string (matches Docker Compose values above)
DATABASE_URL="postgresql://ims_user:ims_password_secure@localhost:5432/ims_db"

# JWT — use a long random string, must match JWT_SECRET in root .env
JWT_SECRET="change-this-to-a-long-random-secret"

# Node environment
NODE_ENV="development"

# Server port
PORT=3001

# CORS — comma-separated list of allowed frontend origins (production)
# ALLOWED_ORIGINS="https://yourdomain.com,https://app.yourdomain.com"

# Superadmin bootstrap (auth.ts /bootstrap route)
# ALLOW_SUPERADMIN_BOOTSTRAP=false
# ALLOW_REMOTE_SUPERADMIN_BOOTSTRAP=false
# DEFAULT_SUPERADMIN_PASSWORD=change-this

# Seed passwords (required when running `npm run seed`)
SEED_SUPERADMIN_PASSWORD=change-before-seeding
SEED_ADMIN_PASSWORD=change-before-seeding
SEED_STAFF_PASSWORD=change-before-seeding

# Map search — Nominatim usage policy requires an identifying user-agent
# NOMINATIM_USER_AGENT=your-app-name/1.0


# -----------------------------------------------------------------------------
# C. Frontend (Vite)  →  frontend/.env
# -----------------------------------------------------------------------------

VITE_API_URL=http://localhost:3001
