{
  "name": "inventory-management-system",
  "version": "0.1.0",
  "description": "Inventory Management System with Interactive 2D Floor Plan Builder",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-start.js",
    "frontend:install": "cd frontend && npm install",
    "backend:install": "cd backend && npm install",
    "install": "npm run frontend:install && npm run backend:install",
    "frontend:dev": "cd frontend && npm run dev",
    "backend:dev": "cd backend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "backend:build": "cd backend && npm run build",
    "backend:db:migrate": "cd backend && npx prisma migrate dev",
    "backend:db:studio": "cd backend && npx prisma studio",
    "start": "npm run dev",
    "control": "powershell -ExecutionPolicy Bypass -File ims-control.ps1",
    "graphify:watch": "graphify watch .",
    "graphify:serve": "node tools/graphify-live/server.mjs",
    "graphify:live": "concurrently \"npm run graphify:watch\" \"npm run graphify:serve\""
  },
  "devDependencies": {
    "chokidar": "^3.6.0",
    "concurrently": "^8.2.2",
    "express": "^4.21.2",
    "playwright": "^1.60.0",
    "ws": "^8.18.0"
  }
}
