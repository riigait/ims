// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Unit values: pcs, dozen, box, pack, g, kg, mg, oz, lb, ton, ml, liter, gallon, cup, mm, cm, m, km, inch, ft, yard, cm2, m2, roll, sheet, can, bottle, bag, carton

model Department {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  users       User[]
  adminUsers  AdminDepartment[]
  staffUsers  StaffDepartment[]
  products    Product[]
  categories  Category[]
  locations   Location[]
  movements   StockMovement[]
  floorPlans  FloorPlan[]
}

model User {
  id                    String     @id @default(cuid())
  name                  String
  email                 String     @unique
  passwordHash          String
  role                  String     @default("staff") // superadmin, admin, staff
  departmentId          String?
  department            Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  initialSetupComplete  Boolean    @default(false)
  adminDepartments      AdminDepartment[]
  staffDepartments      StaffDepartment[]
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  movements             StockMovement[]
  inviteCodes           InviteCode[]
  deleteRequests        DeleteRequest[] @relation("requestedBy")
  reviewedRequests      DeleteRequest[] @relation("reviewedBy")
  passwordRequests      PasswordChangeRequest[] @relation("passwordRequestedBy")
  passwordApprovals     PasswordChangeRequest[] @relation("passwordApprovedBy")
}

model Product {
  id                  String     @id @default(cuid())
  sku                 String     @unique
  name                String
  description         String?
  categoryId          String
  category            Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  departmentId        String?
  department          Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  unit                String     @default("pcs") // pcs, dozen, box, pack, g, kg, mg, oz, lb, ton, ml, liter, gallon, cup, mm, cm, m, km, inch, ft, yard, cm2, m2, roll, sheet, can, bottle, bag, carton
  currentStock        Int        @default(0)
  lowStockThreshold   Int        @default(10)
  locationId          String?
  location            Location?  @relation(fields: [locationId], references: [id], onDelete: SetNull)
  supplier            String?    // Vendor/supplier name
  unitPrice           Float?     // Cost or selling price per unit
  status              String     @default("active") // active, discontinued, obsolete, on-backorder
  expiryDate          DateTime?  // For perishable/time-sensitive items
  leadTimeDays        Int?       // Days until new stock arrives
  notes               String?    // Product-specific notes
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  movements           StockMovement[]
  stockDetails        StockDetail[]
}

model Category {
  id          String     @id @default(cuid())
  name        String
  description String?
  departmentId String?
  department  Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  products    Product[]

  @@unique([name, departmentId])
}

model Location {
  id          String     @id @default(cuid())
  name        String
  type        String     // branch, building, floor, room, rack, shelf
  parentId    String?
  parent      Location?  @relation("LocationParent", fields: [parentId], references: [id], onDelete: Cascade)
  children    Location[] @relation("LocationParent")
  departmentId String?
  department  Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  products    Product[]
  movements   StockMovement[]
  stockDetails StockDetail[]
  floorPlans  FloorPlan[]
}

model StockMovement {
  id            String     @id @default(cuid())
  productId     String
  product       Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  movementType  String     // stock_in, stock_out, adjustment, transfer, damaged, returned
  quantity      Int
  reason        String?
  locationId    String?
  location      Location?  @relation(fields: [locationId], references: [id], onDelete: SetNull)
  modelNumber   String?    // Hardware model number for individual stock item
  serialNumber  String?    // Unique serial number for individual stock item
  macId         String?    // MAC address for network device (if applicable)
  departmentId  String?
  department    Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  stockDetails  StockDetail[] // Individual items linked to this movement
  createdAt     DateTime   @default(now())
}

model StockDetail {
  id            String     @id @default(cuid())
  productId     String
  product       Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  modelNumber   String?    // e.g., Dell XPS 15-9500
  serialNumber  String?    // e.g., SERIAL123456
  macId         String?    // e.g., 00:1A:2B:3C:4D:5E
  dateStock     DateTime?  // When this item was received
  status        String     @default("active") // active, damaged, sold, lost, returned
  locationId    String?
  location      Location?  @relation(fields: [locationId], references: [id], onDelete: SetNull)
  notes         String?    // Additional information about this specific unit
  movementId    String?    // Link to the stock movement (optional, for tracking)
  movement      StockMovement? @relation(fields: [movementId], references: [id], onDelete: SetNull)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String   // CREATE, UPDATE, DELETE, STOCK_IN, STOCK_OUT, LOGIN, etc.
  entityType String   // product, category, location, stock_movement, floor_plan, user
  entityId   String
  changes    String?  // JSON snapshot of what changed
  ipAddress  String?
  createdAt  DateTime @default(now())
}

model FloorPlan {
  id          String     @id @default(cuid())
  name        String
  locationId  String?
  location    Location?  @relation(fields: [locationId], references: [id], onDelete: SetNull)
  departmentId String?
  department  Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  width       Int
  height      Int
  planJson    String     // JSON serialized floor plan data
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model DeleteRequest {
  id          String     @id @default(cuid())
  requestedBy String
  requester   User       @relation("requestedBy", fields: [requestedBy], references: [id], onDelete: Cascade)
  entityType  String     // product, category, location, floor_plan
  entityId    String
  entityName  String
  reason      String?
  status      String     @default("pending") // pending, approved, rejected
  reviewedBy  String?
  reviewer    User?      @relation("reviewedBy", fields: [reviewedBy], references: [id], onDelete: SetNull)
  reviewedAt  DateTime?
  createdAt   DateTime   @default(now())
}

model InviteCode {
  id          String     @id @default(cuid())
  code        String     @unique
  role        String     @default("staff") // admin, staff
  createdBy   String
  creator     User       @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  usedBy      String?
  usedAt      DateTime?
  expiresAt   DateTime
  createdAt   DateTime   @default(now())
}

model AdminDepartment {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId  String
  department    Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now())

  @@unique([userId, departmentId])
}

model StaffDepartment {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId  String
  department    Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now())

  @@unique([userId, departmentId])
}

model PasswordChangeRequest {
  id            String     @id @default(cuid())
  requestedBy   String
  requester     User       @relation("passwordRequestedBy", fields: [requestedBy], references: [id], onDelete: Cascade)
  reason        String?
  status        String     @default("pending") // pending, approved, rejected
  approvedBy    String?
  approver      User?      @relation("passwordApprovedBy", fields: [approvedBy], references: [id], onDelete: SetNull)
  approvedAt    DateTime?
  createdAt     DateTime   @default(now())
}
