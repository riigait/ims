// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Unit values: pcs, dozen, box, pack, g, kg, mg, oz, lb, ton, ml, liter, gallon, cup, mm, cm, m, km, inch, ft, yard, cm2, m2, roll, sheet, can, bottle, bag, carton

enum UserRole {
  superadmin
  admin
  staff
}

enum ProductStatus {
  active
  discontinued
  obsolete
  on_backorder @map("on-backorder")
}

enum LocationType {
  branch
  building
  floor
  room
  rack
  shelf
}

enum MovementType {
  stock_in
  stock_out
  adjustment
  transfer
  damaged
  returned
  opening_stock
  moved_to_department
  borrowed
  lost
  found
  pre_deployment
  post_deployment
  repair_out
  repair_return
  defective
  disposal
}

enum MovementStatus {
  pending
  committed
  cancelled
}

enum ItemCondition {
  new
  good
  fair
  poor
}

enum ItemStatus {
  active
  damaged
  sold
  lost
  returned
  deployed
  borrowed
  disposed
  repair
  defective
}

enum RequestStatus {
  pending
  approved
  rejected
}

model Department {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  users       User[]
  adminUsers  AdminDepartment[]
  staffUsers  StaffDepartment[]
  products    Product[]
  categories  Category[]
  locations   Location[]
  movements         StockMovement[] @relation("MovementFromDepartment")
  receivedMovements StockMovement[] @relation("MovementToDepartment")
  floorPlans     FloorPlan[]
  importRequests ImportRequest[]
  exportRequests ExportRequest[]
}

model User {
  id                    String     @id @default(cuid())
  name                  String
  email                 String     @unique
  passwordHash          String
  role                  UserRole   @default(staff)
  departmentId          String?
  department            Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  initialSetupComplete  Boolean    @default(false)
  adminDepartments      AdminDepartment[]
  staffDepartments      StaffDepartment[]
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  movements             StockMovement[]
  inviteCodes           InviteCode[]
  deleteRequests        DeleteRequest[] @relation("requestedBy")
  reviewedRequests      DeleteRequest[] @relation("reviewedBy")
  passwordRequests           PasswordChangeRequest[] @relation("passwordRequestedBy")
  passwordApprovals          PasswordChangeRequest[] @relation("passwordApprovedBy")
  importRequests             ImportRequest[]         @relation("importSubmittedBy")
  reviewedImportRequests     ImportRequest[]         @relation("importReviewedBy")
  editRequests               EditRequest[]           @relation("editRequestedBy")
  reviewedEditRequests       EditRequest[]           @relation("editReviewedBy")
  exportRequests             ExportRequest[]         @relation("exportRequestedBy")
  reviewedExportRequests     ExportRequest[]         @relation("exportReviewedBy")
  verifyRequests             VerifyRequest[]         @relation("verifyRequestedBy")
  reviewedVerifyRequests     VerifyRequest[]         @relation("verifyReviewedBy")
  failedLoginAttempts        Int                     @default(0)
  lockedUntil                DateTime?

  @@index([role])
  @@index([departmentId])
}

model Product {
  id                  String     @id @default(cuid())
  sku                 String     @unique
  name                String
  description         String?
  categoryId          String
  category            Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  departmentId        String?
  department          Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  unit                String     @default("pcs") // pcs, dozen, box, pack, g, kg, mg, oz, lb, ton, ml, liter, gallon, cup, mm, cm, m, km, inch, ft, yard, cm2, m2, roll, sheet, can, bottle, bag, carton
  currentStock        Int        @default(0)
  lowStockThreshold   Int        @default(10)
  locationId          String?
  location            Location?  @relation(fields: [locationId], references: [id], onDelete: SetNull)
  supplier            String?    // Vendor/supplier name
  unitPrice           Float?     // Cost or selling price per unit
  status              ProductStatus @default(active)
  expiryDate          DateTime?  // For perishable/time-sensitive items
  leadTimeDays        Int?       // Days until new stock arrives
  notes               String?    // Product-specific notes
  source              String?    // manual, csv_import, unknown
  csvImportId         String?    // batch ID assigned per CSV import session
  pendingApproval     Boolean    @default(false)
  archivedAt          DateTime?
  archivedBy          String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  movementItems       StockMovementItem[] @relation("ProductMovementItems")
  stockDetails        StockDetail[]
  editRequests        EditRequest[]

  @@index([departmentId])
  @@index([categoryId])
  @@index([locationId])
  @@index([status])
  @@index([pendingApproval])
  @@index([currentStock])
}

model Category {
  id          String     @id @default(cuid())
  name        String
  description String?
  departmentId String?
  department  Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  products    Product[]

  @@unique([name, departmentId])
  @@index([departmentId])
}

model Location {
  id          String     @id @default(cuid())
  name        String
  type        LocationType
  parentId    String?
  parent      Location?  @relation("LocationParent", fields: [parentId], references: [id], onDelete: Cascade)
  children    Location[] @relation("LocationParent")
  departmentId String?
  department  Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  notes                    String?
  createdAt                DateTime   @default(now())
  updatedAt                DateTime   @updatedAt
  products                 Product[]
  stockDetails             StockDetail[]
  movementItemsFromLocation StockMovementItem[] @relation("MovementItemFromLocation")
  movementItemsToLocation   StockMovementItem[] @relation("MovementItemToLocation")
  floorPlans               FloorPlan[]

  @@index([departmentId])
  @@index([parentId])
}

model StockMovement {
  id              String     @id @default(cuid())
  movementNo      String?    @unique  // e.g., MVT-2026-000001 (auto-generated)
  movementType    MovementType
  status          MovementStatus @default(pending)
  remarks         String?
  departmentId    String?
  department      Department? @relation("MovementFromDepartment", fields: [departmentId], references: [id], onDelete: SetNull)
  toDepartmentId  String?    // destination department for moved_to_department type
  toDepartment    Department? @relation("MovementToDepartment", fields: [toDepartmentId], references: [id], onDelete: SetNull)
  userId          String
  user            User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           StockMovementItem[] // Line items in this movement
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@index([createdAt])
  @@index([departmentId])
  @@index([status])
  @@index([movementType])
}

model StockMovementItem {
  id              String     @id @default(cuid())
  movementId      String
  movement        StockMovement @relation(fields: [movementId], references: [id], onDelete: Cascade)
  stockDetailId   String
  stockDetail     StockDetail @relation(fields: [stockDetailId], references: [id], onDelete: Cascade)
  productId       String
  product         Product    @relation("ProductMovementItems", fields: [productId], references: [id], onDelete: Cascade)
  quantity        Int
  fromLocationId  String?
  fromLocation    Location?  @relation("MovementItemFromLocation", fields: [fromLocationId], references: [id], onDelete: SetNull)
  toLocationId    String?
  toLocation      Location?  @relation("MovementItemToLocation", fields: [toLocationId], references: [id], onDelete: SetNull)
  reason          String?
  createdAt       DateTime   @default(now())
}

model StockDetail {
  id                String     @id @default(cuid())
  stockId           String?    @unique  // e.g., STK-000001 (auto-generated)
  assetTag          String?    @unique  // custom internal tag e.g. IMS-2026-000001
  barcode           String?
  productId         String
  product           Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  modelNumber       String?
  serialNumber      String?
  macId             String?
  dateStock         DateTime?
  brand             String?
  itemType          String?
  condition         ItemCondition? @default(new)
  warrantyExpiry    DateTime?
  warrantyNotes     String?
  currentStatus     ItemStatus @default(active)
  currentLocationId String?
  currentLocation   Location?  @relation(fields: [currentLocationId], references: [id], onDelete: SetNull)
  custodian         String?
  lastCheckedDate   DateTime?
  checkedBy         String?
  notes             String?
  movementItems     StockMovementItem[]
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([stockId])
  @@index([productId])
  @@index([currentLocationId])
  @@index([currentStatus])
}

model DeployedStock {
  id                    String   @id @default(cuid())
  stockId               String
  inventoryItemId       String
  productId             String?
  deployedToName        String?
  deployedToDepartmentId String?
  deployedToLocationId  String?
  deploymentSiteName    String?
  deploymentAddress     String?
  deploymentLatitude    Float?
  deploymentLongitude   Float?
  deploymentDate        DateTime @default(now())
  returnedDate          DateTime?
  status                String   @default("DEPLOYED")
  notes                 String?
  createdByUserId       String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([stockId])
  @@index([inventoryItemId])
  @@index([status])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String   // CREATE, UPDATE, DELETE, STOCK_IN, STOCK_OUT, LOGIN, etc.
  entityType String   // product, category, location, stock_movement, floor_plan, user
  entityId   String
  changes    String?  // JSON snapshot of what changed
  oldValues  String?  // JSON snapshot before change
  newValues  String?  // JSON snapshot after change
  ipAddress  String?
  userAgent  String?
  requestId  String?
  createdAt  DateTime @default(now())
}

model FloorPlan {
  id              String     @id @default(cuid())
  name            String
  locationId      String?
  location        Location?  @relation(fields: [locationId], references: [id], onDelete: SetNull)
  departmentId    String?
  department      Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  width           Int
  height          Int
  planJson        String     // JSON serialized floor plan data
  isApproved      Boolean    @default(false)
  isTemplate      Boolean    @default(false)
  generationScore Int?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  examples        FloorPlanExample[]
  generationLogs  FloorPlanGenerationLog[]
}

model FloorPlanRoomType {
  id           String   @id @default(cuid())
  name         String
  templateType String
  minWidth     Int      @default(120)
  minHeight    Int      @default(80)
  defaultColor String   @default("#dbeafe")
  isRequired   Boolean  @default(false)
  notes        String?
  createdAt    DateTime @default(now())

  @@unique([name, templateType])
}

model FloorPlanRule {
  id             String   @id @default(cuid())
  templateType   String
  ruleType       String   // near, away_from, required_room, restricted_access, must_have
  sourceRoomType String
  targetRoomType String?
  description    String?
  createdAt      DateTime @default(now())
}

model FloorPlanExample {
  id               String    @id @default(cuid())
  floorPlanId      String
  floorPlan        FloorPlan @relation(fields: [floorPlanId], references: [id], onDelete: Cascade)
  templateType     String
  originalData     String
  correctedData    String?
  feedback         String?   // approved, edited, bad_layout
  rating           Int?
  approvedByUserId String?
  createdAt        DateTime  @default(now())
}

model FloorPlanGenerationLog {
  id               String    @id @default(cuid())
  floorPlanId      String
  floorPlan        FloorPlan @relation(fields: [floorPlanId], references: [id], onDelete: Cascade)
  templateUsed     String
  score            Int       @default(0)
  validationResult String?
  userFeedback     String?
  createdAt        DateTime  @default(now())
}

model DeleteRequest {
  id          String     @id @default(cuid())
  requestedBy String
  requester   User       @relation("requestedBy", fields: [requestedBy], references: [id], onDelete: Cascade)
  entityType  String     // product, category, location, floor_plan
  entityId    String
  entityName  String
  reason      String?
  status      RequestStatus @default(pending)
  reviewedBy  String?
  reviewer    User?      @relation("reviewedBy", fields: [reviewedBy], references: [id], onDelete: SetNull)
  reviewedAt  DateTime?
  createdAt   DateTime   @default(now())

  @@index([status])
  @@index([requestedBy])
}

model InviteCode {
  id          String     @id @default(cuid())
  code        String     @unique
  role        UserRole   @default(staff) // valid values: admin, staff only
  createdBy   String
  creator     User       @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  usedBy      String?
  usedAt      DateTime?
  expiresAt   DateTime
  createdAt   DateTime   @default(now())
}

model AdminDepartment {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId  String
  department    Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now())

  @@unique([userId, departmentId])
}

model StaffDepartment {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId  String
  department    Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now())

  @@unique([userId, departmentId])
}

model PasswordChangeRequest {
  id            String     @id @default(cuid())
  requestedBy   String
  requester     User       @relation("passwordRequestedBy", fields: [requestedBy], references: [id], onDelete: Cascade)
  reason        String?
  status        RequestStatus @default(pending)
  approvedBy    String?
  approver      User?      @relation("passwordApprovedBy", fields: [approvedBy], references: [id], onDelete: SetNull)
  approvedAt    DateTime?
  createdAt     DateTime   @default(now())

  @@index([status])
  @@index([requestedBy])
}

model EditRequest {
  id               String    @id @default(cuid())
  productId        String
  product          Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  requestedBy      String
  requester        User      @relation("editRequestedBy", fields: [requestedBy], references: [id], onDelete: Cascade)
  proposedChanges  Json
  reason           String?
  status           RequestStatus @default(pending)
  rejectionReason  String?
  reviewedBy       String?
  reviewer         User?     @relation("editReviewedBy", fields: [reviewedBy], references: [id], onDelete: SetNull)
  reviewedAt       DateTime?
  createdAt        DateTime  @default(now())

  @@index([status])
  @@index([requestedBy])
  @@index([productId])
}

model ImportRequest {
  id           String      @id @default(cuid())
  requestNo    String?     @unique  // e.g., REQ-2026-000001 (auto-generated)
  type         String      // 'csv_import' | 'product_add'
  status       RequestStatus @default(pending)
  productIds   String[]
  csvImportId  String?
  label        String?
  submittedBy  String
  submitter    User        @relation("importSubmittedBy", fields: [submittedBy], references: [id])
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  notes        String?
  expiresAt    DateTime
  reviewedBy   String?
  reviewer     User?       @relation("importReviewedBy", fields: [reviewedBy], references: [id], onDelete: SetNull)
  reviewedAt   DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([status])
  @@index([submittedBy])
  @@index([departmentId])
}

model ImportCounter {
  name       String @id
  nextNumber Int    @default(1)
}

model ExportRequest {
  id              String      @id @default(cuid())
  type            String      // products, categories, locations, unified
  label           String
  csvData         String      // generated CSV content stored at request time
  requestedBy     String
  requester       User        @relation("exportRequestedBy", fields: [requestedBy], references: [id], onDelete: Cascade)
  departmentId    String?
  department      Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  status          RequestStatus @default(pending)
  rejectionReason String?
  reviewedBy      String?
  reviewer        User?       @relation("exportReviewedBy", fields: [reviewedBy], references: [id], onDelete: SetNull)
  reviewedAt      DateTime?
  createdAt       DateTime    @default(now())

  @@index([status])
  @@index([requestedBy])
}

model VerifyRequest {
  id              String    @id @default(cuid())
  stockDetailIds  String[]
  requestedBy     String
  requester       User      @relation("verifyRequestedBy", fields: [requestedBy], references: [id], onDelete: Cascade)
  reason          String?
  status          RequestStatus @default(pending)
  rejectionReason String?
  reviewedBy      String?
  reviewer        User?     @relation("verifyReviewedBy", fields: [reviewedBy], references: [id], onDelete: SetNull)
  reviewedAt      DateTime?
  createdAt       DateTime  @default(now())

  @@index([status])
  @@index([requestedBy])
}
