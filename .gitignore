# Dependencies
node_modules/
venv/
.venv/
__pycache__/

# Build output
dist/
build/
out/
.next/
.nuxt/
.turbo/

# Environment variables (contain secrets)
.env
.env.local
.env.production
.env.development
.env.*.local

# Database files (local data only)
*.db
*.db-journal
*.db-wal
*.db-shm
.backups/

# Logs
logs/
*.log
npm-debug.log*

# Temporary and upload folders
uploads/
temp/
cache/

# Test coverage
coverage/

# OS files
.DS_Store
Thumbs.db
desktop.ini
*.lnk
$RECYCLE.BIN/

# Editor config
.vscode/
.idea/

# Claude Code local settings (machine-specific)
.claude/

# Deployment
.vercel/

# Local-only dev notes and scratch folders
AGENTS.md
mds/
/csv-corrector/
docs/
templates/

# Local-only screenshots and dev artifacts
*-screenshot.png
*-screenshot.jpg

# Archives and binary blobs that shouldn't be in the repo
*.zip
*.tar
*.7z
*.mp4
*.mov
*.pdf

# Image files (blanket ignore — allow tracked assets under frontend/public/)
*.png
*.jpg
*.jpeg
!frontend/public/**/*.png
!frontend/public/**/*.jpg
!frontend/public/**/*.jpeg

# CSV files (blanket ignore — allow tracked tooling formats)
*.csv
!scripts/csv-corrector/format.csv
!scripts/csv-corrector/sample_inventory.csv
